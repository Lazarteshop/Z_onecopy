{
  "entities": {
    "Campaign": {
      "title": "Campaign",
      "description": "A sponsored website campaign that users can view to earn rewards",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "description": { "type": "string" },
        "url": { "type": "string" },
        "reward": { "type": "number" },
        "duration": { "type": "number" },
        "category": { "type": "string" },
        "views": { "type": "number" }
      },
      "required": ["id", "title", "description", "url", "reward", "duration", "category", "views"]
    },
    "Cashout": {
      "title": "Cashout",
      "description": "A cashout request made by a user via GCash",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "number": { "type": "string" },
        "amount": { "type": "number" },
        "status": { "type": "string", "enum": ["pending", "approved", "rejected"] },
        "date": { "type": "string" },
        "userId": { "type": "string" }
      },
      "required": ["id", "name", "number", "amount", "status", "date", "userId"]
    },
    "User": {
      "title": "User",
      "description": "User wallet state and completed tasks",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "balance": { "type": "number" },
        "completedCampaigns": { "type": "array" },
        "createdAt": { "type": "string" }
      },
      "required": ["id", "balance", "completedCampaigns"]
    }
  },
  "firestore": {
    "/campaigns/{campaignId}": {
      "schema": "Campaign",
      "description": "Collection of available sponsored campaigns"
    },
    "/cashouts/{cashoutId}": {
      "schema": "Cashout",
      "description": "Collection of all user cashout requests"
    },
    "/users/{userId}": {
      "schema": "User",
      "description": "Collection of user details containing balances and completed campaign lists"
    }
  }
}
